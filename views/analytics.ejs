<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Analytics</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-gray-100 p-8">

    <div class="max-w-5xl mx-auto">

        <!-- Header Card -->
        <div class="bg-white rounded-xl shadow-md p-6 mb-6">
            <div class="border-b pb-4">
                <a class="ms-4 text-blue-400 cursor-pointer text-sm border rounded px-2 py-1" href="/">Back To Home
                    🏠</a>
            </div>
            <h1 class="text-3xl font-bold mb-4 mt-3">
                URL Analytics
            </h1>

            <div class="space-y-3">
                <p>
                    <span class="font-semibold">Short ID:</span>
                    <span class="bg-blue-100 text-blue-700 px-2 py-1 rounded">
                        <%= analytics.shortId %>
                    </span>
                </p>

                <p>
                    <span class="font-semibold">Original URL:</span>
                    <a href="<%= analytics.redirectUrl %>" target="_blank" class="text-blue-600 underline break-all">
                        <%= analytics.redirectUrl %>
                    </a>
                </p>

                <p>
                    <span class="font-semibold">Total Clicks:</span>
                    <span class="bg-green-100 text-green-700 px-3 py-1 rounded font-bold">
                        <%= totalClicks %>
                    </span>
                </p>

                <p>
                    <span class="font-semibold">Created At:</span>
                    <%= new Date(analytics.createdAt).toLocaleString() %>
                </p>
            </div>
        </div>

        <!-- Visit History -->
        <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <div class="p-4 border-b">
                <h2 class="text-xl font-bold">
                    Visit History
                </h2>
            </div>

            <% if (analytics.visitHistory.length> 0) { %>

                <table class="w-full">
                    <thead class="bg-gray-800 text-white">
                        <tr>
                            <th class="px-4 py-3 text-left">#</th>
                            <th class="px-4 py-3 text-left">Timestamp</th>
                            <th class="px-4 py-3 text-left">Visit Date</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% analytics.visitHistory.forEach((visit, index)=> { %>
                            <tr class="border-b hover:bg-gray-50">
                                <td class="px-4 py-3">
                                    <%= index + 1 %>
                                </td>

                                <td class="px-4 py-3">
                                    <%= visit.timestamp %>
                                </td>

                                <td class="px-4 py-3">
                                    <%= new Date(visit.timestamp).toLocaleString() %>
                                </td>
                            </tr>
                            <% }) %>
                    </tbody>
                </table>

                <% } else { %>

                    <div class="p-8 text-center text-gray-500">
                        No visits yet.
                    </div>

                    <% } %>
        </div>

    </div>

</body>

</html>