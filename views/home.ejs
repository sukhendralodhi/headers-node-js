<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>URL Shortener</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>

<body class="min-h-screen bg-gray-100 py-10">

    <div class="max-w-5xl mx-auto px-4">

        <!-- Header -->
        <div class="bg-white rounded-xl shadow-lg p-4">
            <h1 class="text-2xl font-bold text-center text-gray-800">
                URL Shortener
            </h1>
            <p class="text-center text-sm text-gray-500 mt-1">
                Generate short URLs and track click analytics
            </p>

            <% if (locals.error) { %>
                <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded mb-4">
                    <%= error %>
                </div>
                <script>
                    setTimeout(() => {
                        document.getElementById('error-box')?.remove();
                    }, 300);
                </script>
                <% } %>

                    <% if (locals.url) { %>
                        <div class="mt-6 bg-green-100 border border-green-300 text-green-700 p-4 rounded-lg">
                            <p class="font-semibold">Short URL Generated:</p>
                            <a href="<%= url %>" target="_blank" class="text-blue-600 underline break-all">
                                <%= url %>
                            </a>
                        </div>
                        <% } %>

                            <!-- Form -->
                            <form action="/url" method="POST" class="mt-8">
                                <label for="url" class="block text-gray-700 font-semibold mb-2">
                                    Enter Your Original URL
                                </label>

                                <div class="flex flex-col md:flex-row gap-3">
                                    <input id="url" name="url" type="text" placeholder="https://example.com"
                                        class="flex-1 border border-gray-300 rounded-lg px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500" />

                                    <button type="submit"
                                        class="bg-blue-600 text-white px-6 py-3 rounded-lg font-medium hover:bg-blue-700 transition duration-200 cursor-pointer">
                                        Generate Short URL
                                    </button>
                                </div>
                            </form>
        </div>

        <!-- Table Section -->
        <div class="bg-white rounded-xl shadow-lg mt-8 overflow-hidden">

            <div class="p-6 border-b">
                <h2 class="text-2xl font-bold text-gray-800">
                    URL Analytics
                </h2>
            </div>

            <% if (urls && urls.length> 0) { %>

                <div class="overflow-x-auto border rounded-lg">
                    <div class="max-h-[450px] overflow-y-auto">
                        <table class="w-full">
                            <thead class="bg-gray-800 text-white sticky top-0 z-10">
                                <tr>
                                    <th class="px-6 py-4 text-left">#</th>
                                    <th class="px-6 py-4 text-left">Short ID</th>
                                    <th class="px-6 py-4 text-left">Original URL</th>
                                    <th class="px-6 py-4 text-center">Clicks</th>
                                    <th class="px-6 py-4 text-center">Analytics</th>
                                </tr>
                            </thead>

                            <tbody class="bg-white">
                                <% urls.forEach((url, index)=> { %>
                                    <tr class="border-b hover:bg-gray-50">
                                        <td class="px-6 py-4 font-medium">
                                            <%= index + 1 %>
                                        </td>

                                        <td class="px-6 py-4">
                                            <span
                                                class="bg-blue-100 text-blue-700 px-3 py-1 rounded-full text-sm font-medium">
                                                <%= url.shortId %>
                                            </span>
                                        </td>

                                        <td class="px-6 py-4">
                                            <p class="text-black">
                                                <%= url.redirectUrl.toString().slice(0, 10) + '...' %>
                                            </p>
                                        </td>

                                        <td class="px-6 py-4 text-center">
                                            <span
                                                class="bg-green-100 text-green-700 px-3 py-1 rounded-full font-semibold">
                                                <%= url.visitHistory.length %>
                                            </span>
                                        </td>

                                        <td class="px-6 py-4 text-center">
                                            <a href="/url/analytics/<%= url.shortId %>"
                                                class="inline-flex items-center justify-center bg-indigo-600 text-white px-3 py-1 rounded-lg text-sm hover:bg-indigo-700 transition">
                                                View Analytics
                                            </a>
                                        </td>
                                    </tr>
                                    <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <% } else { %>

                    <div class="p-10 text-center">
                        <p class="text-gray-500 text-lg">
                            No URLs found.
                        </p>
                    </div>

                    <% } %>
        </div>

    </div>

</body>

</html>